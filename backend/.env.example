# ═══════════════════════════════════════════════════════════════════
#  Mnemosyne Backend — Environment Variable Template
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to source control.
# ═══════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
APP_NAME="Mnemosyne"
APP_VERSION="0.1.0"
APP_DESCRIPTION="AI-powered knowledge management backend"
ENVIRONMENT="development"          # development | staging | production
DEBUG=true

# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
HOST="0.0.0.0"
PORT=8000
WORKERS=1                          # increase for production

# ─────────────────────────────────────────────
# Security
# ─────────────────────────────────────────────
SECRET_KEY="change-me-to-a-long-random-secret-key"
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"
ALLOWED_HOSTS="*"

# ─────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────
DATABASE_URL="postgresql+asyncpg://postgres:password@localhost:5432/mnemosyne"
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_URL="redis://localhost:6379/0"

# ─────────────────────────────────────────────
# Vector Database (Qdrant)
# ─────────────────────────────────────────────
QDRANT_URL="http://localhost:6333"
QDRANT_API_KEY=""                  # leave empty for local Qdrant

# ─────────────────────────────────────────────
# AI Providers
# ─────────────────────────────────────────────
GROQ_API_KEY=""
GEMINI_API_KEY=""
OPENAI_API_KEY=""                  # optional fallback

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
LOG_LEVEL="DEBUG"                  # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT="json"                  # json | text
LOG_FILE_PATH="logs/mnemosyne.log"
